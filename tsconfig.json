{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "lib": ["ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "removeComments": false,
    "strict": true,
    "target": "esnext",
    "paths": {
      "@root/*": ["./src/*"],
      "@gen/*": ["./gen/*"]
    }
  }
}
