{
  "name": "music-lyric-model",
  "version": "4.0.0",
  "author": "folltoshe",
  "type": "module",
  "description": "Music Lyric Model",
  "license": "MIT",
  "scripts": {
    "generate": "npm run generate:proto && npm run generate:version",
    "generate:proto": "buf generate proto",
    "generate:version": "tsx script/generate-proto-version.ts",
    "build": "tsx script/build.ts",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "format": "prettier --write ."
  },
  "homepage": "https://github.com/music-lyric/music-lyric-model-node#readme",
  "bugs": {
    "url": "https://github.com/music-lyric/music-lyric-model-node/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/music-lyric/music-lyric-model-node.git"
  },
  "main": "./dist/index.comm.js",
  "module": "./dist/index.ecma.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "dev": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.ecma.js",
      "require": "./dist/index.comm.js"
    },
    "./common": {
      "dev": "./src/common/index.ts",
      "types": "./dist/common/index.d.ts",
      "import": "./dist/common/index.ecma.js",
      "require": "./dist/common/index.comm.js"
    },
    "./parsed": {
      "dev": "./src/parsed/index.ts",
      "types": "./dist/parsed/index.d.ts",
      "import": "./dist/parsed/index.ecma.js",
      "require": "./dist/parsed/index.comm.js"
    },
    "./storage": {
      "dev": "./src/storage/index.ts",
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.ecma.js",
      "require": "./dist/storage/index.comm.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@types/node": "^25.9.4",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tsx": "^4.21.0",
    "typescript": "5.8.2",
    "vite": "^7.3.0"
  }
}
